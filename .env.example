# ==============================================================================
# SHLINK PRODUCTION INFRASTRUCTURE ENVIRONMENT CONFIGURATION (TEMPLATE)
# ==============================================================================
# INSTRUCTIONS:
# 1. Copy this file to '.env' (cp .env.example .env)
# 2. Update all values with secure, unique, and real values.
# 3. Keep '.env' secure and NEVER commit it to version control.
# ==============================================================================

# ------------------------------------------------------------------------------
# SYSTEM CONFIGURATION
# ------------------------------------------------------------------------------
# System timezone for all containers (e.g., UTC, America/New_York, Europe/London)
TZ=UTC

# ------------------------------------------------------------------------------
# DOMAIN AND SSL CONFIGURATION
# ------------------------------------------------------------------------------
# The primary domain where Shlink will be accessible
SHLINK_DOMAIN=arogy.am

# Email address for Let's Encrypt certificate registration (crucial for expiry alerts)
LETSENCRYPT_EMAIL=sunny@arogyamayurveda.com

# ------------------------------------------------------------------------------
# POSTGRESQL CONFIGURATION
# ------------------------------------------------------------------------------
# Credentials for the private database container.
# Generate a strong, random password (e.g., openssl rand -hex 24)
DB_USER=shlink_db_user
DB_PASSWORD=replace_with_a_very_strong_random_password_here_123!
DB_NAME=shlink_db

# ------------------------------------------------------------------------------
# SHLINK CORE CONFIGURATION
# ------------------------------------------------------------------------------
# Cryptographic secret key used for signing JWTs and sessions.
# Generate a strong, random 32+ character string (e.g., openssl rand -base64 48)
SHLINK_SECRET_KEY=replace_with_a_secure_cryptographic_secret_key_here

# Mode of operation (stable is used in docker-compose.yml)
# Enable/disable features
SHLINK_IS_HTTPS_ENABLED=true
SHLINK_GEOLITE2_LICENSE_KEY=

# Option to redirect default domain index page (where users land if they go to https://go.example.com/)
# Can be your main marketing site, or a custom landing page.
SHLINK_DEFAULT_DOMAIN_REDIRECT=https://arogyamshop.com

# Option to redirect invalid/non-existent short URLs (404 Not Found)
SHLINK_REGULAR_404_REDIRECT=https://arogyamshop.com/

# Option to redirect standard invalid/non-existent short URLs (invalid slug style)
SHLINK_INVALID_SHORT_URL_REDIRECT=https://arogyamshop.com/

# ------------------------------------------------------------------------------
# BACKUP CONFIGURATION
# ------------------------------------------------------------------------------
# Directory where backups are temporarily stored (relative to project root)
BACKUP_DIR=./postgres/backups

# Number of daily, weekly, and monthly backups to retain
RETENTION_DAYS=7
RETENTION_WEEKS=4
RETENTION_MONTHS=6
